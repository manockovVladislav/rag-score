# Isolated environment template (GigaChat + local FAISS)
# Copy values into your real environment before running eval.

# -------- LLM backend --------
LLM_BACKEND=gigachat
RAG_LLM_BACKEND=gigachat

# -------- Timeouts (seconds) --------
# RAG generation timeout (0 = no timeout)
MODEL_TIMEOUT_SECONDS=0
# Overall RAGAS task timeout
RAGAS_TIMEOUT_SECONDS=5
RAGAS_MAX_WORKERS=1

# -------- GigaChat API --------
# Required:
# Можно передать ваш API key в credentials:
GIGACHAT_CREDENTIALS=replace_with_real_api_key
# Optional:
GIGACHAT_MODEL=GigaChat-2-Max
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# If your stand requires custom endpoint:
GIGACHAT_BASE_URL=https://your-gigachat-endpoint

# -------- Embeddings model (bge-m3 system) --------
EMBEDDING_MODEL_PATH=/models/bge-m3
EMBEDDING_DEVICE=cpu

# -------- Embeddings model (multilingual-e5-large system) --------
# Пути для отдельной e5-системы:
E5_EMBEDDING_MODEL_PATH=/models/multilingual-e5-large
# Если CUDA нет, оставьте cpu:
E5_EMBEDDING_DEVICE=cpu

# -------- Vector DB --------
# Directory must contain index.faiss + docs.json/docs.jsonl
VECTOR_DB_DIR=/data/vector_db
# Для отдельной e5-системы (сборка через build_vector_db_e5_large.ipynb):
E5_VECTOR_DB_DIR=/data/vector_db_e5_large

# -------- Retriever --------
# Number of nearest contexts to return per question
RETRIEVER_TOP_K=5
E5_RETRIEVER_TOP_K=5
