# Isolated environment template (GigaChat + local FAISS + bge-m3)
# Copy values into your real environment before running eval.

# -------- LLM backend --------
LLM_BACKEND=gigachat
RAG_LLM_BACKEND=gigachat

# -------- Timeouts (seconds) --------
# RAG generation timeout (0 = no timeout)
MODEL_TIMEOUT_SECONDS=0
# Overall RAGAS task timeout
RAGAS_TIMEOUT_SECONDS=5
RAGAS_MAX_WORKERS=1

# -------- GigaChat API --------
# Required:
GIGACHAT_CREDENTIALS=replace_with_real_credentials
# Optional:
GIGACHAT_MODEL=GigaChat-2-Max
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# If your stand requires custom endpoint:
# GIGACHAT_BASE_URL=https://your-gigachat-endpoint

# -------- Embeddings model --------
EMBEDDING_MODEL_PATH=/models/bge-m3
# Use cuda on powerful GPU host:
EMBEDDING_DEVICE=cuda

# -------- Vector DB --------
# Directory must contain index.faiss + docs.json/docs.jsonl
VECTOR_DB_DIR=/data/vector_db

# -------- Retriever --------
# Number of nearest contexts to return per question
RETRIEVER_TOP_K=5
